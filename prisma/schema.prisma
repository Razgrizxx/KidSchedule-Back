generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────

enum UserRole {
  PARENT
  CAREGIVER
}

enum CaregiverVisibility {
  SHARED
  PRIVATE
}

enum CaregiverLinkExpiry {
  SEVEN_DAYS
  THIRTY_DAYS
  NINETY_DAYS
  ONE_YEAR
  NEVER
}

enum CustodyPattern {
  ALTERNATING_WEEKS
  TWO_TWO_THREE
  THREE_FOUR_FOUR_THREE
  FIVE_TWO_TWO_FIVE
  EVERY_OTHER_WEEKEND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum ChangeRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  COUNTER_PROPOSED
}

enum ChangeRequestType {
  ONE_TIME
  PERMANENT
}

enum MediationStatus {
  ACTIVE
  RESOLVED
  ESCALATED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ExpenseCategory {
  EDUCATION
  HEALTH
  FOOD
  CLOTHING
  ACTIVITIES
  TRANSPORT
  OTHER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum TimeFormat {
  TWELVE_HOUR
  TWENTY_FOUR_HOUR
}

enum EventType {
  CUSTODY_TIME
  SCHOOL
  MEDICAL
  ACTIVITY
  VACATION
  OTHER
}

enum EventVisibility {
  SHARED
  PRIVATE
}

enum RepeatPattern {
  NONE
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

enum AppearanceTheme {
  FRIENDLY
  MODERN
  MINIMAL
}

enum OrgType {
  TEAM
  SCHOOL
}

enum OrgRole {
  OWNER
  ADMIN
  VOLUNTEER
  MEMBER
}

enum OrgMemberStatus {
  PENDING
  ACTIVE
}

enum RsvpStatus {
  YES
  NO
  MAYBE
}

enum PlanType {
  FREE
  ESSENTIAL
  PLUS
  COMPLETE
}

enum BillingType {
  INDIVIDUAL
  FAMILY
}

enum HealthRecordType {
  VISIT
  VACCINATION
  LAB_RESULT
  SPECIALIST
  EMERGENCY
  OTHER
}

enum DocumentType {
  PRESCRIPTION
  LAB_ORDER
  LAB_RESULT
  VACCINATION_CARD
  IMAGING
  OTHER
}

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
}

// ─────────────────────────────────────────
//  USER & AUTH
// ─────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         UserRole @default(PARENT)
  avatarUrl            String?
  isVerified           Boolean   @default(false)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  // Google Calendar integration (tokens stored AES-256 encrypted)
  googleRefreshToken   String?
  googleAccessToken    String?
  googleTokenExpiry    DateTime?
  googleCalendarId     String?  // ID of the dedicated "KidSchedule" calendar
  // Outlook Calendar integration (tokens stored AES-256 encrypted)
  outlookAccessToken   String?
  outlookRefreshToken  String?
  outlookTokenExpiry   DateTime?
  outlookCalendarId    String?  // ID of the dedicated "KidSchedule" Outlook calendar
  // iCal subscription feed
  icalFeedToken        String?  @unique  // secret token for the Apple/iCal webcal feed URL
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  phoneVerifications PhoneVerification[]
  familyMemberships  FamilyMember[]
  settings           UserSettings?
  sentMessages       Message[]           @relation("SentMessages")
  sentInvitations    FamilyInvitation[]  @relation("SentInvitations")
  createdCaregivers  Caregiver[]         @relation("CreatedCaregivers")
  expenses           Expense[]
  moments            Moment[]
  changeRequests     ChangeRequest[]     @relation("RequesterChangeRequests")
  respondedRequests  ChangeRequest[]     @relation("ResponderChangeRequests")
  createdEvents      Event[]             @relation("CreatedEvents")
  assignedEvents     Event[]             @relation("AssignedEvents")
  mediationMessages  MediationMessage[]  @relation("MediationMessages")
  proposedResolutions ResolutionProposal[] @relation("ProposedResolutions")
  acceptedResolutions ResolutionProposal[] @relation("AcceptedResolutions")
  adminOf            Organization[]      @relation("OrgAdmin")
  orgMemberships     OrgMembership[]
  orgMembershipsApproved OrgMembership[] @relation("OrgMemberApprover")
  orgEventsCreated   OrgEvent[]          @relation("OrgEventCreator")
  orgRosterLinks     OrgRoster[]         @relation("OrgRosterLinkedUser")
  createdOrgEntities OrgEntity[]         @relation("CreatedOrgEntities")
  orgRsvps           OrgRsvp[]
  orgAnnouncements   Announcement[]      @relation("OrgAnnouncements")
  subscription       Subscription?
  healthRecordsCreated   HealthRecord[]   @relation("HealthRecordCreator")
  healthDocumentsUploaded HealthDocument[] @relation("HealthDocumentUploader")
  medicationsCreated     Medication[]     @relation("MedicationCreator")
  allergiesCreated       Allergy[]        @relation("AllergyCreator")

  @@map("users")
}

model Subscription {
  id                   String          @id @default(uuid())
  userId               String          @unique
  plan                 PlanType        @default(FREE)
  billingType          BillingType     @default(INDIVIDUAL)
  stripeCustomerId     String?         @unique
  stripeSubscriptionId String?         @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model PhoneVerification {
  id        String   @id @default(uuid())
  userId    String
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("phone_verifications")
}

// ─────────────────────────────────────────
//  FAMILY
// ─────────────────────────────────────────

model Family {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        FamilyMember[]
  children       Child[]
  invitations    FamilyInvitation[]
  schedules      Schedule[]
  messages       Message[]
  expenses       Expense[]
  moments        Moment[]
  changeRequests ChangeRequest[]
  settings       FamilySettings?
  events             Event[]
  mediationSessions  MediationSession[]
  healthRecords      HealthRecord[]
  healthDocuments    HealthDocument[]
  medications        Medication[]
  allergies          Allergy[]

  @@map("families")
}

model FamilyMember {
  id       String   @id @default(uuid())
  familyId String
  userId   String
  role     UserRole @default(PARENT)
  joinedAt DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@map("family_members")
}

model FamilyInvitation {
  id          String           @id @default(uuid())
  familyId    String
  invitedBy   String
  email       String
  token       String           @unique @default(uuid())
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  respondedAt DateTime?

  family  Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  inviter User   @relation("SentInvitations", fields: [invitedBy], references: [id])

  @@map("family_invitations")
}

// ─────────────────────────────────────────
//  CHILD
// ─────────────────────────────────────────

model Child {
  id          String   @id @default(uuid())
  familyId    String
  firstName   String
  lastName    String
  dateOfBirth DateTime
  color       String
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family        Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  schedules     Schedule[]
  custodyEvents CustodyEvent[]
  caregivers    ChildCaregiver[]
  moments       Moment[]
  eventChildren EventChild[]
  orgRosters    OrgRoster[]
  healthRecords   HealthRecord[]
  healthDocuments HealthDocument[]
  medications     Medication[]
  allergies       Allergy[]

  @@map("children")
}

// ─────────────────────────────────────────
//  CAREGIVERS
// ─────────────────────────────────────────

model Caregiver {
  id           String              @id @default(uuid())
  familyId     String?
  createdBy    String
  name         String
  phone        String?
  email        String?
  relationship String?
  visibility   CaregiverVisibility @default(PRIVATE)

  inviteToken   String?             @unique
  linkExpiry    CaregiverLinkExpiry @default(SEVEN_DAYS)
  linkExpiresAt DateTime?

  canViewCalendar          Boolean @default(true)
  canViewHealthInfo        Boolean @default(false)
  canViewEmergencyContacts Boolean @default(false)
  canViewAllergies         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator  User             @relation("CreatedCaregivers", fields: [createdBy], references: [id])
  children ChildCaregiver[]
  events   Event[]

  @@map("caregivers")
}

model ChildCaregiver {
  id          String   @id @default(uuid())
  childId     String
  caregiverId String
  assignedAt  DateTime @default(now())

  child     Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  caregiver Caregiver @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@unique([childId, caregiverId])
  @@map("child_caregivers")
}

// ─────────────────────────────────────────
//  SCHEDULE & CUSTODY
// ─────────────────────────────────────────

model Schedule {
  id           String         @id @default(uuid())
  familyId     String
  childId      String
  name         String
  pattern      CustodyPattern
  startDate    DateTime
  durationDays Int            @default(365)
  exchangeDay  Int?
  exchangeTime String?
  parent1Id    String?
  parent2Id    String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  family        Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  child         Child          @relation(fields: [childId], references: [id], onDelete: Cascade)
  custodyEvents CustodyEvent[]

  @@map("schedules")
}

model CustodyEvent {
  id            String   @id @default(uuid())
  scheduleId    String
  childId       String
  familyId      String
  date          DateTime @db.Date
  custodianId   String
  isOverride    Boolean  @default(false)
  googleEventId  String?  // Google Calendar event ID (stored on the first day of each synced block)
  outlookEventId String?  // Outlook Calendar event ID
  createdAt      DateTime @default(now())

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  child    Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date])
  @@map("custody_events")
}

// ─────────────────────────────────────────
//  MESSAGING (immutable + hash chain)
// ─────────────────────────────────────────

model Message {
  id              String        @id @default(uuid())
  familyId        String
  senderId        String
  content         String
  status          MessageStatus @default(SENT)
  contentHash     String
  previousHash    String        @default("0")
  attachmentUrl   String?
  isSystemMessage Boolean       @default(false)
  createdAt       DateTime      @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  sender User   @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

// ─────────────────────────────────────────
//  CHANGE REQUESTS
// ─────────────────────────────────────────

model ChangeRequest {
  id            String              @id @default(uuid())
  familyId      String
  requesterId   String
  responderId   String?
  type          ChangeRequestType
  status        ChangeRequestStatus @default(PENDING)
  originalDate    DateTime?
  requestedDate   DateTime
  requestedDateTo DateTime?
  childId       String?
  reason        String?
  counterDate   DateTime?
  counterReason String?
  resolvedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  requester User   @relation("RequesterChangeRequests", fields: [requesterId], references: [id])
  responder User?  @relation("ResponderChangeRequests", fields: [responderId], references: [id])

  @@map("change_requests")
}

// ─────────────────────────────────────────
//  EXPENSES
// ─────────────────────────────────────────

model Expense {
  id          String          @id @default(uuid())
  familyId    String
  paidBy      String
  childId     String?
  category    ExpenseCategory @default(OTHER)
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("USD")
  description String
  date        DateTime
  receiptUrl  String?
  splitRatio  Decimal         @default(0.5) @db.Decimal(3, 2)
  isSettled   Boolean         @default(false)
  settledAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  payer  User   @relation(fields: [paidBy], references: [id])

  @@map("expenses")
}

// ─────────────────────────────────────────
//  MOMENTS (photo gallery metadata)
// ─────────────────────────────────────────

model Moment {
  id                 String    @id @default(uuid())
  familyId           String
  uploadedBy         String
  childId            String?
  caption            String?
  mediaUrl           String
  cloudinaryPublicId String?
  takenAt            DateTime?
  createdAt          DateTime  @default(now())

  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploadedBy], references: [id])
  child    Child? @relation(fields: [childId], references: [id])

  @@map("moments")
}

// ─────────────────────────────────────────
//  SETTINGS
// ─────────────────────────────────────────

model FamilySettings {
  id             String   @id @default(uuid())
  familyId       String   @unique
  timezone       String   @default("America/New_York")
  transitionDay  String   @default("MONDAY")
  transitionTime String   @default("18:00")
  weekStartsOn   String   @default("MONDAY")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("family_settings")
}

model UserSettings {
  id                 String          @id @default(uuid())
  userId             String          @unique
  timeFormat         TimeFormat      @default(TWELVE_HOUR)
  emailNotifications Boolean         @default(true)
  pushNotifications  Boolean         @default(false)
  appearance         AppearanceTheme @default(FRIENDLY)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─────────────────────────────────────────
//  BLOG
// ─────────────────────────────────────────

model Post {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  category    String    @default("General")
  author      String    @default("KidSchedule Team")
  readTime    Int       @default(1)
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("posts")
}

// ─────────────────────────────────────────
//  EVENTS
// ─────────────────────────────────────────

model Event {
  id           String          @id @default(uuid())
  familyId     String
  createdBy    String
  title        String
  type         EventType       @default(CUSTODY_TIME)
  visibility   EventVisibility @default(SHARED)
  startAt      DateTime
  endAt        DateTime
  allDay       Boolean         @default(false)
  repeat       RepeatPattern   @default(NONE)
  notes         String?
  assignedToId  String?
  caregiverId   String?        // Optional caregiver responsible for this event
  googleEventId  String?  // Google Calendar event ID for bi-directional sync
  outlookEventId String?  // Outlook Calendar event ID
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  family     Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  creator    User         @relation("CreatedEvents", fields: [createdBy], references: [id])
  assignedTo User?        @relation("AssignedEvents", fields: [assignedToId], references: [id])
  caregiver  Caregiver?   @relation(fields: [caregiverId], references: [id], onDelete: SetNull)
  children   EventChild[]

  @@map("events")
}

model EventChild {
  id      String @id @default(uuid())
  eventId String
  childId String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([eventId, childId])
  @@map("event_children")
}

// ─────────────────────────────────────────
//  ORGANIZATIONS (Teams & Schools)
// ─────────────────────────────────────────

model OrgEntity {
  id          String   @id @default(uuid())
  name        String
  type        OrgType
  description String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User         @relation("CreatedOrgEntities", fields: [createdById], references: [id])
  groups    Organization[]

  @@map("org_entities")
}

model Organization {
  id          String    @id @default(uuid())
  name        String
  type        OrgType
  inviteCode  String    @unique
  adminId     String
  isPublic    Boolean   @default(false)
  description String?
  entityId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  admin         User            @relation("OrgAdmin", fields: [adminId], references: [id])
  entity        OrgEntity?      @relation(fields: [entityId], references: [id], onDelete: SetNull)
  members       OrgMembership[]
  events        OrgEvent[]
  venues        Venue[]
  announcements Announcement[]
  customRoles   OrgCustomRole[]
  roster        OrgRoster[]

  @@map("organizations")
}

model OrgCustomRole {
  id                     String   @id @default(uuid())
  organizationId         String
  name                   String
  canCreateEvents        Boolean  @default(false)
  canCreateAnnouncements Boolean  @default(false)
  canCreateVenues        Boolean  @default(false)
  createdAt              DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrgMembership[]

  @@unique([organizationId, name])
  @@map("org_custom_roles")
}

model OrgMembership {
  id             String          @id @default(uuid())
  userId         String
  organizationId String
  role           OrgRole         @default(MEMBER)
  status         OrgMemberStatus @default(ACTIVE)
  approvedById   String?
  approvedAt     DateTime?
  customRoleId   String?
  joinedAt       DateTime        @default(now())

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvedBy   User?          @relation("OrgMemberApprover", fields: [approvedById], references: [id])
  customRole   OrgCustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([userId, organizationId])
  @@map("org_memberships")
}

model Venue {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  address        String?
  mapUrl         String?
  notes          String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events       OrgEvent[]

  @@map("venues")
}

model OrgEvent {
  id             String    @id @default(uuid())
  organizationId String
  createdById    String
  title          String
  type           EventType @default(OTHER)
  startAt        DateTime
  endAt          DateTime
  allDay         Boolean   @default(false)
  notes          String?
  venueId        String?
  maxCapacity    Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("OrgEventCreator", fields: [createdById], references: [id])
  venue        Venue?       @relation(fields: [venueId], references: [id], onDelete: SetNull)
  rsvps        OrgRsvp[]

  @@map("org_events")
}

model OrgRsvp {
  id         String     @id @default(uuid())
  orgEventId String
  userId     String
  status     RsvpStatus
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  orgEvent OrgEvent @relation(fields: [orgEventId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgEventId, userId])
  @@map("org_rsvps")
}

model OrgRoster {
  id            String   @id @default(uuid())
  orgId         String
  firstName     String
  lastName      String
  parentName    String?
  parentEmail   String?
  parentPhone   String?
  notes         String?
  linkedChildId String?
  linkedUserId  String?
  inviteToken   String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  linkedChild Child?       @relation(fields: [linkedChildId], references: [id], onDelete: SetNull)
  linkedUser  User?        @relation("OrgRosterLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)

  @@map("org_roster")
}

model Announcement {
  id             String   @id @default(uuid())
  organizationId String
  authorId       String
  title          String
  content        String
  pinned         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User         @relation("OrgAnnouncements", fields: [authorId], references: [id])

  @@map("announcements")
}

// ─────────────────────────────────────────
//  MEDIATION
// ─────────────────────────────────────────

model MediationSession {
  id        String          @id @default(uuid())
  familyId  String
  topic     String
  status    MediationStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  family    Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)
  messages  MediationMessage[]
  proposals ResolutionProposal[]

  @@map("mediation_sessions")
}

model MediationMessage {
  id        String   @id @default(uuid())
  sessionId String
  senderId  String?
  content   String
  isAI      Boolean  @default(false)
  createdAt DateTime @default(now())

  session MediationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender  User?            @relation("MediationMessages", fields: [senderId], references: [id])

  @@map("mediation_messages")
}

model ResolutionProposal {
  id         String         @id @default(uuid())
  sessionId  String
  proposedBy String
  summary    String
  status     ProposalStatus @default(PENDING)
  acceptedBy String?
  createdAt  DateTime       @default(now())

  session  MediationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  proposer User             @relation("ProposedResolutions", fields: [proposedBy], references: [id])
  accepter User?            @relation("AcceptedResolutions", fields: [acceptedBy], references: [id])

  @@map("resolution_proposals")
}

// ─────────────────────────────────────────
//  HEALTH
// ─────────────────────────────────────────

model HealthRecord {
  id          String           @id @default(uuid())
  familyId    String
  childId     String
  type        HealthRecordType
  title       String
  date        DateTime
  doctorName  String?
  notes       String?
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  family    Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  child     Child          @relation(fields: [childId], references: [id], onDelete: Cascade)
  uploader  User           @relation("HealthRecordCreator", fields: [createdBy], references: [id])
  documents HealthDocument[]

  @@map("health_records")
}

model HealthDocument {
  id                 String       @id @default(uuid())
  familyId           String
  childId            String
  recordId           String?
  type               DocumentType
  title              String
  fileUrl            String
  cloudinaryPublicId String?
  uploadedBy         String
  createdAt          DateTime     @default(now())

  family   Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  child    Child         @relation(fields: [childId], references: [id], onDelete: Cascade)
  uploader User          @relation("HealthDocumentUploader", fields: [uploadedBy], references: [id])
  record   HealthRecord? @relation(fields: [recordId], references: [id], onDelete: SetNull)

  @@map("health_documents")
}

model Medication {
  id           String    @id @default(uuid())
  familyId     String
  childId      String
  name         String
  dosage       String
  frequency    String
  startDate    DateTime
  endDate      DateTime?
  prescribedBy String?
  notes        String?
  isActive     Boolean   @default(true)
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  child    Child  @relation(fields: [childId], references: [id], onDelete: Cascade)
  uploader User   @relation("MedicationCreator", fields: [createdBy], references: [id])

  @@map("medications")
}

model Allergy {
  id        String          @id @default(uuid())
  familyId  String
  childId   String
  name      String
  severity  AllergySeverity
  notes     String?
  createdBy String
  createdAt DateTime        @default(now())

  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  child    Child  @relation(fields: [childId], references: [id], onDelete: Cascade)
  uploader User   @relation("AllergyCreator", fields: [createdBy], references: [id])

  @@map("allergies")
}
