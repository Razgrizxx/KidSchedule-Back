# ─────────────────────────────────────────────────────────────────────────────
#  KidSchedule — Backend Environment Variables
#  Copy this file to .env and fill in the values before running the server.
#  Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────

# Port the NestJS server listens on (default: 3000)
PORT=3000

# Set to "true" to enable dev-mode shortcuts (e.g. skip email verification)
DEV_MODE=false

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma (via @prisma/adapter-pg)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/kidschedule_db

# ── Authentication ────────────────────────────────────────────────────────────

# Secret key used to sign JWT tokens — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# How long access tokens are valid (e.g. 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# ── Email / SMTP ──────────────────────────────────────────────────────────────

# SMTP server hostname (use smtp.mailtrap.io for local testing)
SMTP_HOST=smtp.mailtrap.io

# SMTP port (587 for TLS, 2525 for Mailtrap sandbox, 465 for SSL)
SMTP_PORT=2525

# SMTP credentials
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# "From" address shown in outgoing emails
SMTP_FROM=noreply@kidschedule.app

# ── App ───────────────────────────────────────────────────────────────────────

# Public URL of the frontend app — used to build invitation links in emails
# Change to your production domain before deploying
APP_URL=http://localhost:5173

# ── Google Calendar Integration ───────────────────────────────────────────────

# Google OAuth2 credentials — obtain from https://console.cloud.google.com
# Authorized redirect URI must be registered in the Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Where Google sends the user after consent.
# Local: http://localhost:3000/api/v1/auth/google/callback
# Production: https://api.yourdomain.com/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# 32+ character random key used to AES-256 encrypt stored Google tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=change_me_to_32_plus_random_characters_here

# ── Twilio (Phone Verification) ───────────────────────────────────────────────

# Twilio Account SID — found at https://console.twilio.com under "Account Info"
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token — found next to the Account SID (keep secret)
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio Verify Service SID — create a Verify service at console.twilio.com/verify
# It will look like: VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudinary (Image Storage) ────────────────────────────────────────────────

# Cloudinary credentials — obtain from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
